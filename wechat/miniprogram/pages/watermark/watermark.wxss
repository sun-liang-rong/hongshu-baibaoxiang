page {
  height: 100vh;
  overflow: hidden;
}

.creator-card__top {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.creator-card__glow {
  position: absolute;
  right: 34rpx;
  bottom: 34rpx;
  width: 118rpx;
  height: 118rpx;
  border-radius: 34rpx;
  background:
    linear-gradient(145deg, rgba(255, 49, 80, 0.14), rgba(246, 226, 255, 0.62));
  transform: rotate(12deg);
}

.brand-mark {
  flex: none;
  width: 82rpx;
  height: 82rpx;
  border-radius: 26rpx;
  background: #ff3150;
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 850;
  line-height: 82rpx;
  text-align: center;
  box-shadow: var(--shadow-action);
}

.support-row {
  position: relative;
  z-index: 1;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 24rpx;
}

.support-row text {
  min-height: 44rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.66);
  color: var(--ink-soft);
  font-size: 23rpx;
  font-weight: 750;
  line-height: 44rpx;
  box-shadow: none;
}

.support-row text:first-child {
  color: var(--xhs-red);
  background: rgba(255, 49, 80, 0.1);
}

.panel-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.panel-title {
  margin-bottom: 0;
}

.panel-badge {
  flex: none;
  min-height: 48rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 49, 80, 0.1);
  color: var(--xhs-red);
  font-size: 22rpx;
  font-weight: 850;
  line-height: 48rpx;
}

.textarea {
  display: block;
  min-height: 286rpx;
  margin-top: 24rpx;
  border-radius: 30rpx;
}

.input-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  min-height: 58rpx;
  margin-top: 12rpx;
  color: var(--muted);
  font-size: 23rpx;
  line-height: 1;
}

.input-meta text {
  min-width: 0;
}

.input-meta text:last-child {
  flex: none;
}

.input-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  width: 100%;
  margin-top: 4rpx;
}

.input-actions .button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-width: 0;
  min-height: 92rpx;
  font-size: 27rpx;
  line-height: 1.2;
}

.input-actions .button--ghost {
  border: 0;
  background: rgba(255, 255, 255, 0.82);
  color: var(--xhs-red);
  box-shadow: inset 0 0 0 1rpx rgba(255, 49, 80, 0.14);
}

.input-actions .button[disabled] {
  background: #e2dddf;
  color: #ffffff;
  box-shadow: none;
}

.notice {
  margin-top: 24rpx;
  padding: 24rpx 26rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.54);
  color: var(--ink-soft);
  font-size: 25rpx;
  line-height: 1.6;
  box-shadow: none;
}

.notice__link {
  margin-left: 8rpx;
  color: var(--xhs-red);
  font-weight: 900;
}
