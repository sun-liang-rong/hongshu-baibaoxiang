page {
  min-height: 100vh;
  background: #fff7f8;
}

.page-scroll {
  height: calc(100vh - 88rpx);
}

.page-block {
  padding: 24rpx 24rpx 140rpx;
}

.creator-card {
  position: relative;
  overflow: hidden;
  padding: 30rpx;
  border-radius: 30rpx;
  background: linear-gradient(160deg, #ffffff 0%, #fff8f9 58%, #ffeef2 100%);
  border: 1rpx solid rgba(255, 36, 66, 0.1);
  box-shadow: 0 18rpx 48rpx rgba(36, 18, 22, 0.07);
}

.creator-card::after {
  content: "";
  position: absolute;
  top: -48rpx;
  right: -42rpx;
  width: 170rpx;
  height: 170rpx;
  border-radius: 999rpx;
  background: rgba(255, 36, 66, 0.08);
}

.creator-card__top {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.brand-mark {
  flex: none;
  width: 80rpx;
  height: 80rpx;
  border-radius: 26rpx;
  background: #ff2442;
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 80rpx;
  text-align: center;
  box-shadow: 0 14rpx 30rpx rgba(255, 36, 66, 0.24);
}

.page-kicker {
  color: #ff2442;
  font-size: 24rpx;
  font-weight: 900;
}

.page-title {
  margin-top: 4rpx;
  color: #202124;
  font-size: 46rpx;
  font-weight: 900;
  line-height: 1.15;
}

.page-subtitle {
  position: relative;
  z-index: 1;
  margin-top: 22rpx;
  color: #5e5356;
  font-size: 28rpx;
  line-height: 1.55;
}

.support-row {
  position: relative;
  z-index: 1;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 24rpx;
}

.support-row text {
  padding: 9rpx 17rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #ff2442;
  font-size: 24rpx;
  font-weight: 800;
  box-shadow: inset 0 0 0 1rpx #ffdce2;
}

.input-panel {
  margin-top: 22rpx;
  padding: 26rpx;
  border-radius: 28rpx;
  background: #ffffff;
  border: 1rpx solid rgba(255, 36, 66, 0.08);
  box-shadow: 0 16rpx 42rpx rgba(36, 18, 22, 0.055);
}

.panel-title {
  margin-bottom: 16rpx;
  color: #202124;
  font-size: 31rpx;
  font-weight: 900;
}

.textarea {
  width: 100%;
  min-height: 292rpx;
  padding: 24rpx;
  border-radius: 22rpx;
  background: #fffafa;
  color: #202124;
  font-size: 28rpx;
  line-height: 1.58;
  border: 1rpx solid #ffe5e9;
}

.input-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 22rpx;
  width: 100%;
  overflow: hidden;
}

.button {
  flex: 1 1 0;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 0;
  min-width: 0;
  min-height: 90rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.2;
  text-align: center;
}

.button--primary {
  background: #ff2442;
  color: #ffffff;
  box-shadow: 0 14rpx 28rpx rgba(255, 36, 66, 0.24);
}

.button--ghost {
  background: #fff1f3;
  color: #ff2442;
}

.notice {
  margin-top: 22rpx;
  padding: 22rpx 24rpx;
  border-radius: 22rpx;
  background: #ffffff;
  color: #74696c;
  font-size: 25rpx;
  line-height: 1.58;
  border: 1rpx solid #ffe1e6;
}

.notice__link {
  margin-left: 8rpx;
  color: #ff2442;
  font-weight: 900;
}
