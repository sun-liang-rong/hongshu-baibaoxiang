<navigation-bar title="标题生成" back="{{false}}" color="#1f1f1f" background="#ffffff"></navigation-bar>
<scroll-view class="page-scroll" scroll-y type="list">
  <view class="page-wrap">
    <view class="page-head">
      <view class="page-kicker">标题灵感</view>
      <view class="page-title">生成小红书感标题</view>
      <view class="page-subtitle">输入主题，一次生成多条可收藏、可复制的笔记标题。</view>
    </view>
    <view class="form-card">
      <view class="field">
        <view class="field__label">标题主题</view>
        <input class="input" value="{{topic}}" placeholder="例如：新手做红薯探店" bindinput="onTopicInput" />
      </view>
      <view class="field">
        <view class="field__label">目标人群</view>
        <input class="input" value="{{audience}}" placeholder="例如：本地生活商家、新手博主" bindinput="onAudienceInput" />
      </view>
      <view class="picker-grid">
        <picker mode="selector" range="{{contentTypes}}" value="{{contentTypeIndex}}" bindchange="onContentTypeChange">
          <view class="picker-box">
            <text>内容类型</text>
            <text>{{contentTypes[contentTypeIndex]}}</text>
          </view>
        </picker>
        <picker mode="selector" range="{{styles}}" value="{{styleIndex}}" bindchange="onStyleChange">
          <view class="picker-box">
            <text>标题风格</text>
            <text>{{styles[styleIndex]}}</text>
          </view>
        </picker>
        <picker mode="selector" range="{{counts}}" value="{{countIndex}}" bindchange="onCountChange">
          <view class="picker-box">
            <text>生成数量</text>
            <text>{{counts[countIndex]}} 条</text>
          </view>
        </picker>
      </view>
      <button class="button button--primary" loading="{{loading}}" bindtap="generate">生成标题</button>
    </view>

    <view class="result-section">
      <view class="section-title">生成结果</view>
      <block wx:if="{{generatedTitles.length}}">
        <view wx:for="{{generatedTitles}}" wx:key="*this" class="title-item">
          <view class="title-item__text">{{item}}</view>
          <view class="title-item__actions">
            <button bindtap="copy" data-title="{{item}}">复制</button>
            <button bindtap="favorite" data-title="{{item}}">收藏</button>
            <button bindtap="similar" data-title="{{item}}">相似</button>
          </view>
        </view>
        <button class="button button--ghost" loading="{{loading}}" bindtap="generate">换一批</button>
      </block>
      <empty-state wx:else title="还没有生成标题" desc="输入主题后，一次生成多条红薯风格标题"></empty-state>
    </view>
  </view>
</scroll-view>
