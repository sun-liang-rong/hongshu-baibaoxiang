page {
  height: 100vh;
  overflow: hidden;
}

.picker-grid picker:last-child {
  grid-column: span 2;
}

.picker-box {
  position: relative;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  min-height: 100rpx;
  padding: 16rpx 18rpx 16rpx 22rpx;
  background: #ffffff;
  box-shadow: inset 0 0 0 1rpx rgba(255, 49, 80, 0.08), 0 10rpx 26rpx rgba(84, 62, 72, 0.055);
}

.picker-box::after {
  content: "";
  position: absolute;
  right: 18rpx;
  bottom: 14rpx;
  left: 22rpx;
  height: 1rpx;
  background: linear-gradient(90deg, rgba(255, 49, 80, 0.18), rgba(255, 49, 80, 0));
}

.picker-box__label,
.picker-box__value {
  display: block;
}

.picker-box__label {
  color: var(--muted);
  font-size: 21rpx;
  font-weight: 750;
  line-height: 1.25;
}

.picker-box__value {
  margin-top: 6rpx;
  color: var(--ink);
  font-size: 27rpx;
  font-weight: 850;
  line-height: 1.25;
}

.picker-box__chevron {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 38rpx;
  height: 38rpx;
  flex: none;
  border-radius: 50%;
  background: rgba(255, 49, 80, 0.08);
  color: var(--xhs-red);
  font-size: 26rpx;
  font-weight: 850;
  line-height: 38rpx;
}

.form-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.panel-badge {
  flex: none;
  min-height: 48rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 49, 80, 0.1);
  color: var(--xhs-red);
  font-size: 22rpx;
  font-weight: 850;
  line-height: 48rpx;
}

.form-card .button {
  margin-top: 24rpx;
}

.cta-button {
  margin-top: 28rpx;
}

.result-section {
  background: rgba(255, 255, 255, 0.5);
}

.result-section empty-state {
  display: block;
}

.result-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  min-height: 58rpx;
}

.title-item {
  position: relative;
  margin-top: 20rpx;
  padding: 26rpx 20rpx 22rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.72);
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.78), 0 12rpx 30rpx rgba(84, 62, 72, 0.045);
}

.title-item::before {
  content: "";
  position: absolute;
  top: 24rpx;
  bottom: 24rpx;
  left: 12rpx;
  width: 5rpx;
  border-radius: 999rpx;
  background: var(--xhs-red);
}

.title-item__text {
  padding-left: 14rpx;
  color: var(--ink);
  font-size: 29rpx;
  font-weight: 850;
  line-height: 1.5;
}

.title-item__actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10rpx;
  margin-top: 20rpx;
  width: 100%;
}

.title-item__actions button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-width: 0;
  min-height: 66rpx;
  padding: 0;
  border: 0;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.74);
  color: var(--ink-soft);
  font-size: 25rpx;
  font-weight: 850;
  line-height: 66rpx;
}

.title-item__actions button:first-child {
  background: #ff3150;
  color: #ffffff;
  box-shadow: 0 10rpx 22rpx rgba(255, 36, 66, 0.18);
}

.title-item__actions button:last-child {
  background: transparent;
  box-shadow: none;
}

.title-item__actions button.favorited {
  background: rgba(255, 49, 80, 0.1) !important;
  color: var(--xhs-red) !important;
  box-shadow: inset 0 0 0 1rpx rgba(255, 49, 80, 0.14);
}

.refresh-button {
  margin-top: 24rpx;
}
