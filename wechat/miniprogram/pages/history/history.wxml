<navigation-bar title="历史记录" color="#25232a" background="transparent"></navigation-bar>
<view class="page">
  <filter-tabs filters="{{filters}}" active="{{activeType}}" bind:change="switchType"></filter-tabs>

  <scroll-view
    class="list-scroll"
    scroll-y
    type="list"
    lower-threshold="120"
    bindscrolltolower="loadMore"
  >
    <block wx:if="{{items.length}}">
      <record-card
        wx:for="{{items}}"
        wx:key="id"
        item="{{item}}"
        bind:open="open"
        bind:copy="copy"
        bind:remove="remove"
      ></record-card>
      <button
        wx:if="{{hasMore}}"
        class="load-more-button"
        loading="{{loadingMore}}"
        bindtap="loadMore"
      >
        加载更多
      </button>
      <button class="clear-button" bindtap="clearAll">清空记录</button>
    </block>
    <empty-state wx:else title="暂无历史记录" desc="使用去水印、标题生成或文案生成后会自动保存"></empty-state>
  </scroll-view>
</view>
