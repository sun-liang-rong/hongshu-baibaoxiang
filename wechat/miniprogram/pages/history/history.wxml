<navigation-bar title="历史记录" color="#1f1f1f" background="#ffffff"></navigation-bar>
<view class="page">
  <view class="filter-row">
    <view
      wx:for="{{filters}}"
      wx:key="label"
      class="filter {{activeType === item.value ? 'filter--active' : ''}}"
      bindtap="switchType"
      data-type="{{item.value}}"
    >
      {{item.label}}
    </view>
  </view>

  <scroll-view class="list-scroll" scroll-y type="list">
    <block wx:if="{{items.length}}">
      <view wx:for="{{items}}" wx:key="id" class="record-card">
        <view class="record-card__head">
          <status-pill text="{{item.label}}"></status-pill>
          <text class="record-card__time">{{item.time}}</text>
        </view>
        <view class="record-card__title" bindtap="open" data-id="{{item.id}}">{{item.title}}</view>
        <view class="record-card__summary">{{item.summary}}</view>
        <view class="record-card__actions">
          <button bindtap="open" data-id="{{item.id}}">查看</button>
          <button bindtap="copy" data-id="{{item.id}}">复制</button>
          <button bindtap="remove" data-id="{{item.id}}">删除</button>
        </view>
      </view>
      <button class="clear-button" bindtap="clearAll">清空记录</button>
    </block>
    <empty-state wx:else title="暂无历史记录" desc="使用去水印、标题生成或文案生成后会自动保存"></empty-state>
  </scroll-view>
</view>
