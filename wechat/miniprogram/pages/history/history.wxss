page {
  min-height: 100vh;
  background: #fff7f8;
}

.page {
  min-height: calc(100vh - 88rpx);
}

.filter-row {
  display: flex;
  gap: 14rpx;
  padding: 24rpx 24rpx 14rpx;
  overflow-x: auto;
}

.filter {
  flex: none;
  min-height: 62rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #74696c;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 62rpx;
  border: 1rpx solid #ffe1e6;
  box-shadow: 0 8rpx 22rpx rgba(36, 18, 22, 0.035);
}

.filter--active {
  background: #ff2442;
  color: #ffffff;
  border-color: #ff2442;
  box-shadow: 0 12rpx 26rpx rgba(255, 36, 66, 0.22);
}

.list-scroll {
  height: calc(100vh - 180rpx);
  padding: 0 24rpx 40rpx;
  box-sizing: border-box;
}

.record-card {
  margin-top: 18rpx;
  padding: 24rpx;
  border-radius: 26rpx;
  background: #ffffff;
  border: 1rpx solid rgba(255, 36, 66, 0.08);
  box-shadow: 0 16rpx 42rpx rgba(36, 18, 22, 0.055);
}

.record-card__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.record-card__time {
  color: #9a8b8f;
  font-size: 23rpx;
}

.record-card__title {
  margin-top: 18rpx;
  color: #202124;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.45;
}

.record-card__summary {
  margin-top: 10rpx;
  color: #74696c;
  font-size: 26rpx;
  line-height: 1.52;
}

.record-card__actions {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 18rpx;
}

.record-card__actions button,
.clear-button {
  min-height: 70rpx;
  border-radius: 999rpx;
  background: #fffafa;
  color: #74696c;
  font-size: 25rpx;
  font-weight: 900;
  line-height: 70rpx;
  border: 1rpx solid #f2e7e9;
}

.record-card__actions button:first-child {
  background: #fff1f3;
  color: #ff2442;
  border-color: #ffdce2;
}

.clear-button {
  margin: 24rpx 0 40rpx;
  color: #ff2442;
  background: #ffffff;
  border-color: #ffdce2;
}
