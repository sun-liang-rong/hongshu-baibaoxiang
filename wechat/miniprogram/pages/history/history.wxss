page {
  height: 100vh;
  overflow: hidden;
}

.page {
  display: flex;
  min-height: 0;
  flex: 1;
  flex-direction: column;
}

.list-scroll {
  padding: 0 30rpx calc(env(safe-area-inset-bottom) + 56rpx);
  box-sizing: border-box;
}

.clear-button {
  min-height: 74rpx;
  margin: 24rpx 0 16rpx;
  border: 0;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.7);
  color: var(--xhs-red);
  font-size: 26rpx;
  font-weight: 850;
  line-height: 74rpx;
  box-shadow: inset 0 0 0 1rpx rgba(255, 49, 80, 0.14);
}

.load-more-button {
  min-height: 72rpx;
  margin: 22rpx 0 16rpx;
  border: 0;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
  color: #625b66;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 72rpx;
  box-shadow: inset 0 0 0 1rpx rgba(38, 33, 46, 0.08);
}
