<navigation-bar title="解析结果" color="#1f1f1f" background="#ffffff"></navigation-bar>
<view class="page-scroll">
  <block wx:if="{{result}}">
    <view class="result-page">
      <view class="section section--first">
        <view class="section__title">无水印素材</view>
        <block wx:if="{{result.videoUrl}}">
          <view class="video-card">
            <video
              id="watermarkVideo"
              class="media-video"
              src="{{result.videoUrl}}"
              poster="{{result.coverUrl}}"
              controls
              show-center-play-btn
              show-fullscreen-btn="{{false}}"
              object-fit="contain"
            ></video>
            <button class="video-fullscreen" bindtap="openVideoFullscreen">全屏播放</button>
          </view>
          <button class="button button--ghost" bindtap="saveVideo">保存视频</button>
        </block>
        <view wx:else class="media-grid">
          <view wx:for="{{result.images}}" wx:key="*this" class="media-item">
            <image class="media-image" src="{{item}}" mode="aspectFill" bindtap="previewImage" data-url="{{item}}"></image>
            <button class="small-button" bindtap="saveImage" data-url="{{item}}">保存图片</button>
          </view>
        </view>
      </view>

      <view class="section">
        <view class="section__title">原文案</view>
        <view class="content-box">{{result.content}}</view>
        <button class="button button--primary" bindtap="copyContent">复制文案</button>
      </view>
    </view>
  </block>
  <empty-state wx:else title="暂无解析结果" desc="请先粘贴红薯链接并完成解析"></empty-state>
</view>
