page {
  height: 100vh;
  overflow: hidden;
}

.result-page {
  padding-bottom: 64rpx;
}

.section {
  margin-top: 22rpx;
}

.section--first {
  margin-top: 0;
}

.section__title {
  margin-bottom: 18rpx;
}

.video-card {
  overflow: hidden;
  border: 0;
  border-radius: 30rpx;
  background: #111111;
  box-shadow: 0 14rpx 38rpx rgba(84, 62, 72, 0.12);
}

.media-video {
  display: block;
  width: 100%;
  height: 430rpx;
  background: #111111;
}

.media-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.media-item {
  overflow: hidden;
  border: 0;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.7);
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.76), 0 10rpx 28rpx rgba(84, 62, 72, 0.055);
}

.media-image {
  display: block;
  width: 100%;
  height: 230rpx;
  background: #f1edef;
}

.media-image:active {
  opacity: 0.86;
}

.small-button {
  width: 100%;
  border: 0;
  border-top: 1rpx solid rgba(60, 51, 58, 0.06);
  border-radius: 0;
  background: rgba(255, 49, 80, 0.08);
  color: var(--xhs-red);
}

.section > .button {
  margin-top: 18rpx;
}

.result-actions {
  display: grid;
  grid-template-columns: 1.1fr 0.9fr;
  gap: 14rpx;
  margin-top: 18rpx;
}

.result-actions .button {
  min-width: 0;
  min-height: 78rpx;
  font-size: 25rpx;
  line-height: 78rpx;
}
