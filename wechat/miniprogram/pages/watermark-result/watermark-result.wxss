page {
  min-height: 100vh;
  background: #fff7f8;
}

.page-scroll {
  min-height: calc(100vh - 88rpx);
}

.result-page {
  padding: 24rpx 24rpx 56rpx;
}

.section {
  border-radius: 28rpx;
  background: #ffffff;
  border: 1rpx solid rgba(255, 36, 66, 0.08);
  box-shadow: 0 16rpx 42rpx rgba(36, 18, 22, 0.055);
}

.section {
  margin-top: 22rpx;
  padding: 26rpx;
}

.section--first {
  margin-top: 0;
}

.section__title {
  margin-bottom: 18rpx;
  color: #202124;
  font-size: 31rpx;
  font-weight: 900;
}


.video-card {
  overflow: hidden;
  border-radius: 24rpx;
  background: #111111;
  border: 1rpx solid #ffe5e9;
}

.media-video {
  display: block;
  width: 100%;
  height: 430rpx;
  background: #111111;
}

.video-fullscreen {
  width: 100%;
  min-height: 78rpx;
  border-radius: 0;
  background: #191919;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 78rpx;
}

.media-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.media-item {
  overflow: hidden;
  border-radius: 22rpx;
  background: #fffafa;
  border: 1rpx solid #ffe5e9;
}

.media-image {
  width: 100%;
  height: 230rpx;
  background: #f1edef;
}

.media-image:active {
  opacity: 0.86;
}

.small-button {
  width: 100%;
  min-height: 74rpx;
  border-radius: 0;
  background: #fff1f3;
  color: #ff2442;
  font-size: 25rpx;
  font-weight: 900;
  line-height: 74rpx;
}

.content-box {
  padding: 24rpx;
  border-radius: 24rpx;
  background: #fffafa;
  color: #202124;
  font-size: 28rpx;
  line-height: 1.66;
  white-space: pre-wrap;
  border: 1rpx solid #ffe5e9;
}

.button {
  margin-top: 18rpx;
  min-height: 88rpx;
  border-radius: 999rpx;
  font-size: 27rpx;
  font-weight: 900;
  line-height: 88rpx;
}

.button--primary {
  background: #ff2442;
  color: #ffffff;
  box-shadow: 0 14rpx 28rpx rgba(255, 36, 66, 0.24);
}

.button--ghost {
  background: #fff1f3;
  color: #ff2442;
}
