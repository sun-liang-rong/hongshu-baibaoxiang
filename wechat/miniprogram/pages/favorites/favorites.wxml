<navigation-bar title="我的收藏" color="#25232a" background="transparent"></navigation-bar>
<view class="page">
  <filter-tabs filters="{{filters}}" active="{{activeType}}" bind:change="switchType"></filter-tabs>

  <scroll-view
    class="list-scroll"
    scroll-y
    type="list"
    lower-threshold="120"
    bindscrolltolower="loadMore"
  >
    <block wx:if="{{items.length}}">
      <record-card
        wx:for="{{items}}"
        wx:key="id"
        item="{{item}}"
        bind:open="open"
        bind:copy="copy"
        bind:remove="remove"
      ></record-card>
      <button
        wx:if="{{hasMore}}"
        class="load-more-button"
        loading="{{loadingMore}}"
        bindtap="loadMore"
      >
        加载更多
      </button>
    </block>
    <empty-state wx:else title="暂无收藏" desc="在解析结果、标题和文案页面点击收藏后会出现在这里"></empty-state>
  </scroll-view>
</view>
