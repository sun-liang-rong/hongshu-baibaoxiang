page {
  height: 100vh;
  overflow: hidden;
}

.page {
  display: flex;
  min-height: 0;
  flex: 1;
  flex-direction: column;
}

.list-scroll {
  padding: 0 30rpx 172rpx;
  box-sizing: border-box;
}

.load-more-button {
  min-height: 72rpx;
  margin: 22rpx 0 40rpx;
  border: 0;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
  color: #625b66;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 72rpx;
  box-shadow: inset 0 0 0 1rpx rgba(38, 33, 46, 0.08);
}
