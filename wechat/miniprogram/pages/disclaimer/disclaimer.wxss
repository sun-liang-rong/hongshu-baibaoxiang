page {
  min-height: 100vh;
  background: #fff7f8;
}

.page-scroll {
  height: calc(100vh - 88rpx);
}

.doc-page {
  padding: 24rpx 24rpx 48rpx;
}

.doc-card {
  padding: 28rpx;
  border-radius: 28rpx;
  background: #ffffff;
  border: 1rpx solid rgba(255, 36, 66, 0.08);
  box-shadow: 0 16rpx 42rpx rgba(36, 18, 22, 0.055);
}

.doc-title {
  margin-bottom: 20rpx;
  color: #202124;
  font-size: 34rpx;
  font-weight: 900;
}

.notice-row {
  display: flex;
  gap: 16rpx;
  margin-top: 18rpx;
}

.notice-dot {
  flex: none;
  width: 14rpx;
  height: 14rpx;
  margin-top: 14rpx;
  border-radius: 50%;
  background: #ff2442;
  box-shadow: 0 6rpx 12rpx rgba(255, 36, 66, 0.22);
}

.notice-text {
  flex: 1;
  color: #74696c;
  font-size: 28rpx;
  line-height: 1.65;
}
