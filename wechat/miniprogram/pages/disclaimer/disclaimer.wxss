page {
  height: 100vh;
  overflow: hidden;
}

.doc-card {
  padding: 30rpx 28rpx;
}

.doc-title {
  margin-bottom: 20rpx;
  color: var(--ink);
  font-size: 34rpx;
  font-weight: 850;
  line-height: 1.28;
}

.notice-row {
  display: flex;
  gap: 16rpx;
  margin-top: 18rpx;
  padding: 18rpx;
  border: 0;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.62);
}

.notice-dot {
  width: 14rpx;
  height: 14rpx;
  flex: none;
  margin-top: 14rpx;
  border-radius: 50%;
  background: var(--amber);
  box-shadow: 0 6rpx 12rpx rgba(180, 107, 18, 0.18);
}

.notice-text {
  flex: 1;
  color: var(--ink-soft);
  font-size: 27rpx;
  line-height: 1.66;
}
