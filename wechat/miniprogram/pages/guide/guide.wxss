page {
  height: 100vh;
  overflow: hidden;
}

.doc-card {
  position: relative;
  margin-bottom: 20rpx;
  padding: 28rpx;
  overflow: hidden;
}

.doc-card::before {
  content: "";
  position: absolute;
  left: 0;
  top: 28rpx;
  bottom: 28rpx;
  width: 6rpx;
  border-radius: 999rpx;
  background: rgba(255, 49, 80, 0.72);
}

.doc-card__title {
  margin-bottom: 18rpx;
  color: var(--ink);
  font-size: 31rpx;
  font-weight: 850;
  line-height: 1.32;
}

.step-row {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.step-dot {
  width: 42rpx;
  height: 42rpx;
  flex: none;
  border-radius: 50%;
  background: rgba(255, 49, 80, 0.1);
  color: var(--xhs-red);
  font-size: 23rpx;
  font-weight: 850;
  line-height: 42rpx;
  text-align: center;
  box-shadow: none;
}

.step-text {
  flex: 1;
  color: var(--ink-soft);
  font-size: 27rpx;
  line-height: 1.6;
}
