page {
  min-height: 100vh;
  background: #fff7f8;
}

.page-scroll {
  height: calc(100vh - 88rpx);
}

.doc-page {
  padding: 24rpx 24rpx 48rpx;
}

.doc-card {
  margin-bottom: 20rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: #ffffff;
  border: 1rpx solid rgba(255, 36, 66, 0.08);
  box-shadow: 0 16rpx 42rpx rgba(36, 18, 22, 0.055);
}

.doc-card__title {
  margin-bottom: 18rpx;
  color: #202124;
  font-size: 32rpx;
  font-weight: 900;
}

.step-row {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.step-dot {
  flex: none;
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  background: #ff2442;
  color: #ffffff;
  font-size: 23rpx;
  font-weight: 900;
  line-height: 42rpx;
  text-align: center;
  box-shadow: 0 8rpx 18rpx rgba(255, 36, 66, 0.2);
}

.step-text {
  flex: 1;
  color: #74696c;
  font-size: 27rpx;
  line-height: 1.58;
}
