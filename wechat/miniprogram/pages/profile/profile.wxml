<navigation-bar title="我的" back="{{false}}" color="#25232a" background="transparent"></navigation-bar>
<scroll-view class="page-scroll" scroll-y type="list">
  <view class="profile">
    <view class="user-card">
      <view class="avatar">{{avatarText}}</view>
      <view class="user-card__main">
        <view class="nickname">{{nickname}}</view>
        <view class="subtext">免费工具 MVP 版本</view>
      </view>
    </view>

    <view class="stat-row">
      <view wx:for="{{quotaStats}}" wx:key="key" class="stat-item stat-item--{{item.key}}">
        <view class="stat-item__num">{{item.num}}</view>
        <view class="stat-item__label">{{item.label}}</view>
      </view>
    </view>

    <view class="link-list">
      <view wx:for="{{links}}" wx:key="title" class="link-item" bindtap="go" data-url="{{item.url}}">
        <view>
          <view class="link-item__title">{{item.title}}</view>
          <view class="link-item__desc">{{item.desc}}</view>
        </view>
        <view class="link-item__arrow">›</view>
      </view>
    </view>

    <view class="about-box">
      今日次数会在每天 00:00 后恢复，具体额度以后台配置为准。
    </view>
  </view>
</scroll-view>
