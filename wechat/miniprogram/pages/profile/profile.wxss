page {
  height: 100vh;
  overflow: hidden;
}

.user-card {
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 34rpx 30rpx;
  border-radius: 38rpx;
  background:
    linear-gradient(145deg, rgba(255, 255, 255, 0.78) 0%, rgba(255, 247, 244, 0.76) 52%, rgba(232, 248, 244, 0.68) 100%);
}

.user-card::before {
  content: "";
  position: absolute;
  right: -38rpx;
  top: -42rpx;
  width: 170rpx;
  height: 170rpx;
  border: 24rpx solid rgba(15, 159, 136, 0.1);
  border-radius: 50%;
}

.avatar {
  position: relative;
  z-index: 1;
  width: 98rpx;
  height: 98rpx;
  flex: none;
  border-radius: 30rpx;
  background: #ff3150;
  color: #ffffff;
  font-size: 40rpx;
  font-weight: 850;
  line-height: 98rpx;
  text-align: center;
  box-shadow: var(--shadow-action);
}

.user-card__main {
  position: relative;
  z-index: 1;
  min-width: 0;
}

.nickname {
  color: var(--ink);
  font-size: 33rpx;
  font-weight: 850;
  line-height: 1.25;
}

.subtext {
  margin-top: 8rpx;
  color: var(--ink-soft);
  font-size: 25rpx;
}

.stat-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin-top: 18rpx;
}

.stat-item {
  min-width: 0;
  padding: 22rpx 8rpx;
  border: 0;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.62);
  text-align: center;
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.72), 0 10rpx 28rpx rgba(84, 62, 72, 0.04);
}

.stat-item__num {
  color: var(--xhs-red);
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1.1;
}

.stat-item--title .stat-item__num {
  color: var(--mint);
}

.stat-item--copywriting .stat-item__num {
  color: var(--amber);
}

.stat-item__label {
  margin-top: 8rpx;
  color: var(--muted);
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1.25;
}

.link-list {
  margin-top: 22rpx;
  overflow: hidden;
  border-radius: 34rpx;
}

.link-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 118rpx;
  padding: 0 26rpx;
  border-bottom: 1rpx solid rgba(60, 51, 58, 0.06);
}

.link-item:last-child {
  border-bottom: 0;
}

.link-item__title {
  color: var(--ink);
  font-size: 29rpx;
  font-weight: 850;
}

.link-item__desc {
  margin-top: 6rpx;
  color: var(--muted);
  font-size: 24rpx;
  line-height: 1.35;
}

.link-item__arrow {
  color: var(--xhs-red);
  font-size: 44rpx;
  line-height: 1;
}

.about-box {
  margin-top: 22rpx;
  padding: 26rpx;
  border-radius: 30rpx;
  color: var(--ink-soft);
  font-size: 26rpx;
  line-height: 1.6;
  box-shadow: none;
}
