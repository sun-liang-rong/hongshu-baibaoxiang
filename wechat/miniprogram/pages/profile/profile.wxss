page {
  min-height: 100vh;
  background: #fff7f8;
}

.page-scroll {
  height: calc(100vh - 88rpx);
}

.profile {
  padding: 24rpx 24rpx 140rpx;
}

.user-card,
.link-list,
.about-box {
  border-radius: 28rpx;
  background: #ffffff;
  border: 1rpx solid rgba(255, 36, 66, 0.08);
  box-shadow: 0 16rpx 42rpx rgba(36, 18, 22, 0.055);
}

.user-card {
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 32rpx 28rpx;
  background: linear-gradient(160deg, #ffffff 0%, #fff8f9 62%, #ffeef2 100%);
}

.user-card::after {
  content: "";
  position: absolute;
  right: -36rpx;
  top: -42rpx;
  width: 164rpx;
  height: 164rpx;
  border-radius: 999rpx;
  background: rgba(255, 36, 66, 0.08);
}

.avatar {
  position: relative;
  z-index: 1;
  width: 98rpx;
  height: 98rpx;
  border-radius: 34rpx;
  background: #ff2442;
  color: #ffffff;
  font-size: 40rpx;
  font-weight: 900;
  line-height: 98rpx;
  text-align: center;
  box-shadow: 0 14rpx 30rpx rgba(255, 36, 66, 0.24);
}

.user-card__main {
  position: relative;
  z-index: 1;
  min-width: 0;
}

.nickname {
  color: #202124;
  font-size: 33rpx;
  font-weight: 900;
}

.subtext {
  margin-top: 8rpx;
  color: #74696c;
  font-size: 25rpx;
}

.stat-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin-top: 18rpx;
}

.stat-item {
  padding: 22rpx 10rpx;
  border-radius: 22rpx;
  background: #ffffff;
  border: 1rpx solid rgba(255, 36, 66, 0.08);
  text-align: center;
  box-shadow: 0 10rpx 28rpx rgba(36, 18, 22, 0.04);
}

.stat-item__num {
  color: #ff2442;
  font-size: 35rpx;
  font-weight: 900;
  line-height: 1.1;
}

.stat-item__label {
  margin-top: 8rpx;
  color: #8a7d80;
  font-size: 23rpx;
  font-weight: 800;
}

.link-list {
  margin-top: 18rpx;
  overflow: hidden;
}

.link-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 120rpx;
  padding: 0 26rpx;
  border-bottom: 1rpx solid #f7e9ec;
}

.link-item__title {
  color: #202124;
  font-size: 29rpx;
  font-weight: 900;
}

.link-item__desc {
  margin-top: 6rpx;
  color: #8a7d80;
  font-size: 24rpx;
}

.link-item__arrow {
  color: #ff8a9c;
  font-size: 44rpx;
}

.about-box {
  margin-top: 18rpx;
  padding: 24rpx;
  color: #74696c;
  font-size: 26rpx;
  line-height: 1.58;
}
