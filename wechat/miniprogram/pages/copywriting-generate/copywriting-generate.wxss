page {
  min-height: 100vh;
  background: #fff7f8;
}

.page-scroll {
  height: calc(100vh - 88rpx);
}

.page-wrap {
  padding: 24rpx 24rpx 140rpx;
}

.page-head {
  position: relative;
  overflow: hidden;
  padding: 30rpx;
  border-radius: 30rpx;
  background: linear-gradient(160deg, #ffffff 0%, #fff8f9 62%, #ffeef2 100%);
  border: 1rpx solid rgba(255, 36, 66, 0.1);
  box-shadow: 0 18rpx 48rpx rgba(36, 18, 22, 0.07);
}

.page-head::after {
  content: "";
  position: absolute;
  right: -30rpx;
  bottom: -56rpx;
  width: 190rpx;
  height: 190rpx;
  border-radius: 999rpx;
  background: rgba(255, 36, 66, 0.07);
}

.page-kicker {
  position: relative;
  z-index: 1;
  display: inline-flex;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #ff2442;
  font-size: 24rpx;
  font-weight: 900;
  box-shadow: inset 0 0 0 1rpx #ffdce2;
}

.page-title {
  position: relative;
  z-index: 1;
  margin-top: 18rpx;
  color: #202124;
  font-size: 43rpx;
  font-weight: 900;
  line-height: 1.22;
}

.page-subtitle {
  position: relative;
  z-index: 1;
  margin-top: 12rpx;
  color: #5e5356;
  font-size: 27rpx;
  line-height: 1.55;
}

.form-card,
.result-section {
  border-radius: 28rpx;
  background: #ffffff;
  border: 1rpx solid rgba(255, 36, 66, 0.08);
  box-shadow: 0 16rpx 42rpx rgba(36, 18, 22, 0.055);
}

.form-card,
.result-section {
  padding: 26rpx;
}

.form-card {
  margin-top: 22rpx;
}

.field + .field {
  margin-top: 22rpx;
}

.field__label,
.section-title {
  color: #202124;
  font-size: 30rpx;
  font-weight: 900;
}

.input,
.textarea {
  margin-top: 12rpx;
  width: 100%;
  padding: 0 22rpx;
  border-radius: 20rpx;
  background: #fffafa;
  color: #202124;
  font-size: 28rpx;
  box-sizing: border-box;
  border: 1rpx solid #ffe5e9;
}

.input {
  min-height: 88rpx;
}

.textarea {
  min-height: 158rpx;
  padding-top: 18rpx;
  line-height: 1.55;
}

.picker-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-top: 22rpx;
}

.picker-box {
  min-height: 96rpx;
  padding: 14rpx 18rpx;
  border-radius: 20rpx;
  background: #fffafa;
  color: #202124;
  font-size: 26rpx;
  line-height: 1.45;
  display: flex;
  flex-direction: column;
  justify-content: center;
  border: 1rpx solid #ffe5e9;
}

.picker-box text:first-child {
  color: #9a8b8f;
  font-size: 23rpx;
  font-weight: 700;
}

.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 20rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: #fffafa;
  color: #202124;
  font-size: 28rpx;
  font-weight: 800;
  border: 1rpx solid #ffe5e9;
}

.button {
  margin-top: 22rpx;
  min-height: 88rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 88rpx;
}

.button--primary {
  background: #ff2442;
  color: #ffffff;
  box-shadow: 0 14rpx 28rpx rgba(255, 36, 66, 0.24);
}

.button--ghost {
  background: #fff1f3;
  color: #ff2442;
}

.result-section {
  margin-top: 22rpx;
}

.title-item {
  position: relative;
  margin-top: 18rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #fffafa;
  border: 1rpx solid #ffe5e9;
}

.title-item::before {
  content: "";
  position: absolute;
  left: 0;
  top: 24rpx;
  bottom: 24rpx;
  width: 6rpx;
  border-radius: 999rpx;
  background: #ff2442;
}

.title-item__text {
  color: #202124;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.48;
}

.title-item__actions {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 18rpx;
}

.title-item__actions button {
  min-height: 68rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #74696c;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 68rpx;
  border: 1rpx solid #f2e7e9;
}

.title-item__actions button:first-child {
  background: #fff1f3;
  color: #ff2442;
  border-color: #ffdce2;
}

.result-title {
  margin-top: 18rpx;
  color: #202124;
  font-size: 33rpx;
  font-weight: 900;
  line-height: 1.4;
}

.content-box {
  margin-top: 18rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #fffafa;
  color: #202124;
  font-size: 28rpx;
  line-height: 1.68;
  white-space: pre-wrap;
  border: 1rpx solid #ffe5e9;
}

.tag-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.tag {
  padding: 8rpx 15rpx;
  border-radius: 999rpx;
  background: #fff1f3;
  color: #ff2442;
  font-size: 24rpx;
  font-weight: 900;
}

.suggestions {
  margin-top: 20rpx;
  padding: 20rpx;
  border-radius: 22rpx;
  background: #ffffff;
  border: 1rpx solid #f2e7e9;
  color: #202124;
}

.suggestions__title {
  margin-bottom: 10rpx;
  font-size: 28rpx;
  font-weight: 900;
}

.suggestions__item {
  margin-top: 8rpx;
  color: #74696c;
  font-size: 26rpx;
  line-height: 1.5;
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.action-grid__wide {
  grid-column: span 2;
}
