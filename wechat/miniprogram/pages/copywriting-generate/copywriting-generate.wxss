page {
  height: 100vh;
  overflow: hidden;
}

.form-card .button {
  margin-top: 24rpx;
}

.picker-box {
  position: relative;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  min-height: 100rpx;
  padding: 16rpx 18rpx 16rpx 22rpx;
  background: #ffffff;
  box-shadow: inset 0 0 0 1rpx rgba(255, 49, 80, 0.08), 0 10rpx 26rpx rgba(84, 62, 72, 0.055);
}

.picker-box::after {
  content: "";
  position: absolute;
  right: 18rpx;
  bottom: 14rpx;
  left: 22rpx;
  height: 1rpx;
  background: linear-gradient(90deg, rgba(255, 49, 80, 0.18), rgba(255, 49, 80, 0));
}

.picker-box__label,
.picker-box__value {
  display: block;
}

.picker-box__label {
  color: var(--muted);
  font-size: 21rpx;
  font-weight: 750;
  line-height: 1.25;
}

.picker-box__value {
  margin-top: 6rpx;
  color: var(--ink);
  font-size: 27rpx;
  font-weight: 850;
  line-height: 1.25;
}

.picker-box__chevron {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 38rpx;
  height: 38rpx;
  flex: none;
  border-radius: 50%;
  background: rgba(255, 49, 80, 0.08);
  color: var(--xhs-red);
  font-size: 26rpx;
  font-weight: 850;
  line-height: 38rpx;
}

.form-head,
.result-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.panel-badge {
  flex: none;
  min-height: 48rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 49, 80, 0.1);
  color: var(--xhs-red);
  font-size: 22rpx;
  font-weight: 850;
  line-height: 48rpx;
}

.cta-button {
  margin-top: 28rpx;
}

.result-section {
  padding-bottom: 30rpx;
  background: rgba(255, 255, 255, 0.5);
}

.result-section empty-state {
  display: block;
}

.result-title {
  margin-top: 18rpx;
  color: var(--ink);
  font-size: 32rpx;
  font-weight: 850;
  line-height: 1.42;
}

.tag-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.suggestions {
  margin-top: 20rpx;
  padding: 20rpx;
  border: 0;
  border-radius: 28rpx;
  background: var(--mint-soft);
  color: var(--ink);
}

.suggestions__title {
  margin-bottom: 10rpx;
  color: var(--mint);
  font-size: 28rpx;
  font-weight: 850;
}

.suggestions__item {
  position: relative;
  margin-top: 8rpx;
  padding-left: 22rpx;
  color: var(--ink-soft);
  font-size: 26rpx;
  line-height: 1.52;
}

.suggestions__item::before {
  content: "";
  position: absolute;
  left: 2rpx;
  top: 17rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--mint);
}

.action-grid {
  display: grid;
  grid-template-columns: 1.1fr 0.9fr;
  gap: 14rpx;
  margin-top: 24rpx;
}

.action-grid .button {
  margin-top: 0;
  min-width: 0;
  min-height: 76rpx;
  font-size: 25rpx;
  line-height: 76rpx;
}

.action-grid__wide {
  grid-column: span 2;
}
