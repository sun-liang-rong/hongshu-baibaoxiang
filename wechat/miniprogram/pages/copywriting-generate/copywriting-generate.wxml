<navigation-bar title="文案生成" back="{{false}}" color="#1f1f1f" background="#ffffff"></navigation-bar>
<scroll-view class="page-scroll" scroll-y type="list">
  <view class="page-wrap">
    <view class="page-head">
      <view class="page-kicker">笔记文案</view>
      <view class="page-title">生成完整种草文案</view>
      <view class="page-subtitle">围绕主题、卖点和人群，生成标题、正文、话题和配图建议。</view>
    </view>
    <view class="form-card">
      <view class="field">
        <view class="field__label">文案主题</view>
        <input class="input" value="{{topic}}" placeholder="例如：夏季通勤穿搭" data-field="topic" bindinput="onInput" />
      </view>
      <view class="field">
        <view class="field__label">产品或服务</view>
        <input class="input" value="{{productName}}" placeholder="选填" data-field="productName" bindinput="onInput" />
      </view>
      <view class="field">
        <view class="field__label">核心卖点</view>
        <textarea class="textarea" value="{{sellingPoints}}" placeholder="选填，例如：省时间、显瘦、适合新手" data-field="sellingPoints" bindinput="onInput" />
      </view>
      <view class="field">
        <view class="field__label">目标人群</view>
        <input class="input" value="{{audience}}" placeholder="选填，例如：上班族、新手妈妈" data-field="audience" bindinput="onInput" />
      </view>
      <view class="picker-grid">
        <picker mode="selector" range="{{styles}}" value="{{styleIndex}}" bindchange="onStyleChange">
          <view class="picker-box">
            <text>文案风格</text>
            <text>{{styles[styleIndex]}}</text>
          </view>
        </picker>
        <picker mode="selector" range="{{lengths}}" value="{{lengthIndex}}" bindchange="onLengthChange">
          <view class="picker-box">
            <text>文案长度</text>
            <text>{{lengths[lengthIndex]}}</text>
          </view>
        </picker>
      </view>
      <view class="switch-row">
        <text>生成话题标签</text>
        <switch checked="{{includeTags}}" color="#ff2442" bindchange="onIncludeTagsChange" />
      </view>
      <button class="button button--primary" loading="{{loading}}" bindtap="generate">生成文案</button>
    </view>

    <view class="result-section">
      <view class="section-title">生成结果</view>
      <block wx:if="{{result}}">
        <view class="result-title">{{result.title}}</view>
        <view class="content-box">{{result.body}}</view>
        <view class="tag-wrap">
          <view wx:for="{{result.tags}}" wx:key="*this" class="tag">#{{item}}</view>
        </view>
        <view class="suggestions">
          <view class="suggestions__title">配图建议</view>
          <view wx:for="{{result.imageSuggestions}}" wx:key="*this" class="suggestions__item">{{item}}</view>
        </view>
        <view class="action-grid">
          <button class="button button--primary" bindtap="copyAll">复制全文</button>
          <button class="button button--ghost" bindtap="favorite">收藏</button>
          <button class="button button--ghost action-grid__wide" loading="{{loading}}" bindtap="generate">重新生成</button>
        </view>
      </block>
      <empty-state wx:else title="还没有生成文案" desc="补充主题、卖点和风格后生成完整红薯文案"></empty-state>
    </view>
  </view>
</scroll-view>
