.status-pill {
  display: inline-flex;
  align-items: center;
  min-height: 44rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: var(--mint-soft);
  color: var(--mint);
  font-size: 23rpx;
  font-weight: 900;
  line-height: 44rpx;
  box-shadow: inset 0 0 0 1rpx rgba(15, 159, 136, 0.16);
}
