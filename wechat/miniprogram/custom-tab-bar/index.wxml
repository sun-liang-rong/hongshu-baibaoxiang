<view class="tab-shell">
  <view class="tab-bar">
    <view
      wx:for="{{list}}"
      wx:key="pagePath"
      class="tab-item {{selected === index ? 'tab-item--active' : ''}}"
      data-path="{{item.pagePath}}"
      data-index="{{index}}"
      bindtap="switchTab"
    >
      <view class="tab-icon">
        <image src="{{selected === index ? item.selectedIconPath : item.iconPath}}" mode="aspectFit"></image>
      </view>
      <text>{{item.text}}</text>
    </view>
  </view>
</view>
