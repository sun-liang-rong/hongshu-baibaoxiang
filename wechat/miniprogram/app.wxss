page {
  color: #202124;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", Helvetica, Arial, sans-serif;
  background: #fff7f8;
}

view,
text,
input,
textarea,
button {
  box-sizing: border-box;
}

button {
  display: block;
  width: auto;
  min-width: 0;
  margin: 0;
  padding: 0;
  border: 0;
  box-sizing: border-box;
}

button::after {
  border: 0;
  display: none;
}

input,
textarea {
  caret-color: #ff2442;
}

.xhs-card {
  border: 1rpx solid rgba(255, 36, 66, 0.08);
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 44rpx rgba(36, 18, 22, 0.06);
}

.xhs-soft-panel {
  border: 1rpx solid #ffe2e7;
  border-radius: 22rpx;
  background: linear-gradient(180deg, #fff8f9 0%, #ffffff 100%);
}

.xhs-chip {
  display: inline-flex;
  align-items: center;
  min-height: 48rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #fff1f3;
  color: #ff2442;
  font-size: 24rpx;
  font-weight: 800;
}

.xhs-section-title {
  color: #202124;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.25;
}
