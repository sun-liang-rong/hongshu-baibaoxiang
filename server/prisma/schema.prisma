generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum GenerateType {
  watermark
  title
  copywriting
}

enum GenerateStatus {
  success
  failed
}

model GenerateRecord {
  id            BigInt         @id @default(autoincrement())
  openid        String?        @db.VarChar(64)
  type          GenerateType
  topic         String
  input         Json
  output        Json?
  title         String?
  summary       String?
  status        GenerateStatus @default(success)
  aiProvider    String?        @map("ai_provider")
  aiModel       String?        @map("ai_model")
  promptVersion String?        @map("prompt_version")
  errorMessage  String?        @map("error_message")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  @@index([openid, type, createdAt])
  @@map("generate_records")
}

model Favorite {
  id        BigInt       @id @default(autoincrement())
  openid    String       @db.VarChar(64)
  type      GenerateType
  refId     String       @map("ref_id")
  title     String
  summary   String?      @db.Text
  payload   Json
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  @@unique([openid, type, refId])
  @@index([openid, type, createdAt])
  @@map("favorites")
}
